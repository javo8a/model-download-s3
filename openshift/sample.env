JOB_NAME=my-model-s3-sync-job
PVC_CLAIM_NAME=my-model-pvc
SERVICE_ACCOUNT_NAME=hfsa
S3_CREDENTIALS_SECRET=my-model-s3-credentials
S3_URI=s3://my-models-bucket/path/to/my-model/
# Optional (defaults in model-sync-from-s3-template.yaml): MOUNT_PATH, STORAGE_INITIALIZER_IMAGE,
# HF_HUB_DISABLE_TELEMETRY, MEMORY_REQUEST, MEMORY_LIMIT, S3_USE_HTTPS, S3_ENDPOINT,
# AWS_ENDPOINT_URL, S3_VERIFY_SSL (leave empty for public AWS S3)
